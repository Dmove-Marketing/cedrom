---
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import '../styles/eventos-corporativos.css';
---

<Base
  title="Cedrom Eventos — Eventos Corporativos em São Paulo"
  ogImage="/images/og-eventos-corporativos.jpg"
>
<link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
<link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link slot="head" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@300;400&display=swap" rel="stylesheet" />

<!-- =========== SEAL TEMPLATE =========== -->
<template id="seal-tpl">
  <span class="seal" aria-hidden="true">
    <svg viewBox="0 0 100 100">
      <defs>
        <path id="circlePath" d="M 50,50 m -37,0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0" />
      </defs>
      <circle cx="50" cy="50" r="46" fill="none" stroke="currentColor" stroke-width="0.6" opacity="0.55"/>
      <circle cx="50" cy="50" r="40" fill="none" stroke="currentColor" stroke-width="0.6" opacity="0.9"/>
      <text class="ring-text">
        <textPath href="#circlePath" startOffset="0%">CEDROM EVENTOS · SÃO PAULO · DESDE 2000 · </textPath>
      </text>
      <text class="mono" x="50" y="50" text-anchor="middle" dominant-baseline="central" font-size="34">C</text>
    </svg>
  </span>
</template>

<!-- =========== HEADER =========== -->
<header id="header">
  <nav class="nav">
    <a href="#top" class="brand" aria-label="Cedrom Eventos — início">
      <span class="brand-name"><strong>Cedrom Eventos</strong></span>
    </a>
    <div class="nav-links" id="navLinks">
      <a href="#sobre">Sobre</a>
      <a href="#espaco">Espaço</a>
      <a href="#galeria">Galeria</a>
      <a href="#contato">Contato</a>
    </div>
    <button class="menu-toggle" id="menuToggle" aria-label="Abrir menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

<main id="top">

  <!-- =========== HERO =========== -->
  <section class="hero">
    <div class="wrap hero-inner">
      <span class="eyebrow">Vila São Francisco · Butantã · São Paulo</span>
      <h1>O cenário certo para encontros corporativos<em>que geram grandes negócios</em></h1>
      <p class="hero-sub">Ambientes versáteis e estrutura completa para eventos corporativos de diferentes formatos.</p>
      <div class="hero-cta">
        <a href="#contato" class="btn solid">Solicitar Orçamento</a>
      </div>
    </div>
  </section>

  <!-- =========== SOBRE =========== -->
  <section class="about" id="sobre">
    <div class="wrap about-grid">
      <div class="reveal">
        <span class="eyebrow">Espaço Cedrom</span>
        <div class="years" style="margin-top:18px">24<small>Anos recebendo eventos corporativos</small></div>
        <div class="rule"></div>
        <h2>24 anos recebendo eventos que aproximam marcas às pessoas</h2>
        <p class="lead">Localizado na Vila São Francisco, no Butantã, em São Paulo, o Cedrom Eventos oferece uma combinação única entre natureza, infraestrutura e flexibilidade para receber convenções, confraternizações, treinamentos, lançamentos e encontros corporativos.</p>
        <p class="lead" style="margin-top:22px">Com ambientes integrados e uma equipe experiente, criamos experiências que fortalecem relacionamentos, valorizam a sua marca e proporcionam conforto aos convidados.</p>
      </div>
      <div class="ph about-photo filled reveal">
        <!-- IMAGEM SOBRE: substituir src abaixo pela URL enviada -->
        <img src="https://media.dmove.com.br/clients/cedrom/photos/c79224a8-827c-4073-ae86-e445092a035f.webp" alt="Ambiente corporativo no Cedrom Eventos" loading="eager" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;z-index:1" />
      </div>
    </div>
  </section>

  <!-- =========== ESPAÇO =========== -->
  <section class="structure" id="espaco">
    <div class="wrap">
      <div class="center-head reveal">
        <span class="eyebrow">Estrutura completa para o seu evento</span>
        <h2 class="section-title">Estrutura completa para que sua equipe foque no que importa</h2>
        <p class="lead">Espaços versáteis e serviços integrados para garantir uma operação fluida do início ao fim.</p>
      </div>
      <div class="amen-grid">
        <!-- amenities injetados via eventos-corporativos.js -->
      </div>
    </div>
  </section>

  <!-- =========== GALERIA =========== -->
  <section class="moments" id="galeria">
    <div class="wrap">
      <div class="center-head reveal">
        <span class="eyebrow">Galeria</span>
        <h2 class="section-title">Eventos que refletem o posicionamento<br>de cada empresa</h2>
      </div>
      <div class="gal reveal">
        <div class="ph filled gal-mob-top-2"><img src="https://media.dmove.com.br/clients/cedrom/photos/9c281619-224c-46ff-8d37-fb4ed17ab2d0.webp"  alt="Evento corporativo no Cedrom Eventos" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;z-index:1" /></div>
        <div class="ph filled"><img src="https://media.dmove.com.br/clients/cedrom/photos/4bb7ef30-2d4f-47b1-8608-7a06c91cbd9d.webp"                        alt="Evento corporativo no Cedrom Eventos" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;z-index:1" /></div>
        <div class="ph filled"><img src="https://media.dmove.com.br/clients/cedrom/photos/IMG-20240820-WA0020.webp"                                           alt="Evento corporativo no Cedrom Eventos" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;z-index:1" /></div>
        <div class="ph filled"><img src="https://media.dmove.com.br/clients/cedrom/photos/corporativos_(19).webp"                                             alt="Evento corporativo no Cedrom Eventos" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;z-index:1" /></div>
        <div class="ph filled"><img src="https://media.dmove.com.br/clients/cedrom/photos/corporativos_(18).webp"                                             alt="Evento corporativo no Cedrom Eventos" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;z-index:1" /></div>
        <div class="ph filled"><img src="https://media.dmove.com.br/clients/cedrom/photos/corporativos_(6).webp"                                              alt="Evento corporativo no Cedrom Eventos" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;z-index:1" /></div>
        <div class="ph filled"><img src="https://media.dmove.com.br/clients/cedrom/photos/corporativos_(7).webp"                                              alt="Evento corporativo no Cedrom Eventos" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;z-index:1" /></div>
        <div class="ph filled gal-mob-top"><img src="https://media.dmove.com.br/clients/cedrom/photos/corporativos_(14).webp"                                 alt="Evento corporativo no Cedrom Eventos" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;z-index:1" /></div>
      </div>
    </div>
  </section>

  <!-- =========== CONTATO =========== -->
  <section class="contact" id="contato">
    <div class="wrap contact-grid">
      <div class="contact-aside reveal">
        <span class="eyebrow">Fale conosco</span>
        <h2 class="section-title">Vamos conversar sobre o seu próximo evento?</h2>
        <p class="lead">Preencha o formulário e receba uma proposta alinhada aos objetivos, formato e necessidades da sua empresa.</p>
        <div class="rule"></div>
        <p style="font-size:.85rem;letter-spacing:.06em;color:var(--muted)">Vila São Francisco · São Paulo / SP</p>
      </div>

      <form
        id="form-lead-form-corp"
        name="lead-form-corp"
        data-form-id="lead-form-corp"
        data-project={config.project_slug}
        data-submit-url={config.forms['lead-form'].webhooks[0]}
        data-redirect={config.forms['lead-form'].redirect_on_success}
        data-grid-id="corpFormGrid"
        data-success-id="corpFormSuccess"
        novalidate
      >
        <div class="hp-field" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;pointer-events:none">
          <label for="corp_website">Deixe este campo em branco</label>
          <input type="text" id="corp_website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <div id="corpFormGrid" class="form">
          <div class="field">
            <label for="c-nome">Nome</label>
            <input id="c-nome" type="text" name="Nome" placeholder="Seu nome completo" required />
          </div>
          <div class="field">
            <label for="c-empresa">Empresa</label>
            <input id="c-empresa" type="text" name="Empresa" placeholder="Nome da empresa" />
          </div>
          <div class="field">
            <label for="c-telefone">Telefone</label>
            <input id="c-telefone" type="tel" name="WhatsApp" placeholder="(00) 00000-0000" required data-mask="phone" />
          </div>
          <div class="field">
            <label for="c-email">E-mail</label>
            <input id="c-email" type="email" name="E-mail" placeholder="seuemail@exemplo.com" />
          </div>
          <div class="field">
            <label for="c-data">Data do evento</label>
            <input id="c-data" type="text" name="Data do evento" placeholder="DD/MM/AAAA" readonly data-datepicker autocomplete="off" />
          </div>
          <div class="field">
            <label for="c-convidados">Número de pessoas</label>
            <input id="c-convidados" type="number" name="Convidados" placeholder="Nº estimado" />
          </div>
          <div class="field full">
            <label for="c-tipo">Tipo de evento</label>
            <select id="c-tipo" name="Tipo de evento">
              <option value="" disabled selected>Selecione o tipo de evento</option>
              <option value="Convenção">Convenção</option>
              <option value="Confraternização corporativa">Confraternização corporativa</option>
              <option value="Treinamento">Treinamento</option>
              <option value="Lançamento de produto">Lançamento de produto</option>
              <option value="Reunião de negócios">Reunião de negócios</option>
              <option value="Outros">Outros</option>
            </select>
          </div>
          <div class="field full">
            <label for="c-detalhes">Detalhes adicionais</label>
            <textarea id="c-detalhes" name="Detalhes adicionais" placeholder="Conte um pouco sobre o evento que você está planejando"></textarea>
          </div>
          <div class="submit-row">
            <button type="submit" class="btn solid" id="corpFormSubmitBtn">
              <span class="btn-text">Enviar solicitação</span>
              <span class="btn-loading" style="display:none">Enviando...</span>
            </button>
            <span class="form-note">Retornamos o seu contato em breve.</span>
          </div>
          <div class="form-success" id="corpFormSuccess">
            <svg viewBox="0 0 24 24" width="20" height="20"><polyline points="20 6 9 17 4 12" stroke="currentColor" fill="none" stroke-width="2"/></svg>
            Solicitação recebida! Em breve entraremos em contato.
          </div>
        </div>
      </form>
    </div>
  </section>
</main>

<!-- =========== FOOTER =========== -->
<footer>
  <div class="wrap">
    <img src="https://media.dmove.com.br/clients/cedrom/photos/cedron.webp" alt="Cedrom Eventos" class="f-logo" />
    <div class="f-rule"></div>
    <div class="f-copy">Copyright © 2026 Cedrom Eventos — Todos os direitos reservados</div>
    <div class="f-dev">Desenvolvimento: <a href="https://dmove.com.br" target="_blank" rel="noopener"><img src="https://media.dmove.com.br/clients/dmove/photos/logo-dmove.webp" alt="Dmove" class="f-dev-logo" /></a></div>
  </div>
</footer>

<!-- floating whatsapp -->
<a href="#contato" class="wa-float" aria-label="Fale no WhatsApp">
  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21 5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm0 18.13c-1.52 0-3.01-.41-4.3-1.18l-.31-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 01-1.26-4.35c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 012.41 5.82c0 4.54-3.69 8.41-8.24 8.41h.13zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.24-1.48-1.38-1.73-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.22.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28z"/></svg>
</a>

</Base>
<script>
  import '../scripts/eventos-corporativos.js';
  import { initForms } from '../scripts/forms.ts';
  import flatpickr from 'flatpickr';
  import { Portuguese } from 'flatpickr/dist/l10n/pt.js';
  import 'flatpickr/dist/flatpickr.min.css';

  flatpickr.localize(Portuguese);

  function initExtras() {
    document.querySelectorAll<HTMLInputElement>('[data-datepicker]').forEach((el) => {
      if ((el as any)._flatpickr) return;
      flatpickr(el, { dateFormat: 'd/m/Y', minDate: 'today', disableMobile: false });
    });

    document.querySelectorAll<HTMLInputElement>('[data-mask="phone"]').forEach((el) => {
      if (el.dataset.maskInit) return;
      el.dataset.maskInit = '1';
      el.addEventListener('input', () => {
        let v = el.value.replace(/\D/g, '').slice(0, 11);
        if (v.length > 10) v = v.replace(/^(\d{2})(\d{5})(\d{4}).*/, '($1) $2-$3');
        else if (v.length > 6) v = v.replace(/^(\d{2})(\d{4})(\d*)/, '($1) $2-$3');
        else if (v.length > 2) v = v.replace(/^(\d{2})(\d*)/, '($1) $2');
        else if (v.length > 0) v = v.replace(/^(\d*)/, '($1');
        el.value = v;
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => { initForms(); initExtras(); });
  } else {
    initForms();
    initExtras();
  }
</script>
</Base>
